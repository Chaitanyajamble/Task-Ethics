    def get_trial_balance(self, as_of_date: str, company_id: str = "001") -> dict:
        """
        Retrieve trial balance as of a given date.

        Args:
            as_of_date : Date string 'YYYY-MM-DD'
            company_id : Company/entity identifier
        """
        result = api_request("GET", f"/finance/trial-balance?date={as_of_date}&company={company_id}")
        print(f"[FINANCE] Trial Balance as of {as_of_date}: {len(result.get('accounts', []))} accounts")
        return result

    def get_profit_loss(self, from_date: str, to_date: str) -> dict:
        """Generate Profit & Loss statement for a date range."""
        result = api_request("GET", f"/finance/profit-loss?from={from_date}&to={to_date}")
        if "summary" in result:
            s = result["summary"]
            print(f"[FINANCE] P&L  Revenue: ₹{s.get('revenue', 0):,.2f} | "
                  f"Expenses: ₹{s.get('expenses', 0):,.2f} | "
                  f"Net Profit: ₹{s.get('net_profit', 0):,.2f}")
        return result

    def get_balance_sheet(self, as_of_date: str) -> dict:
        """Fetch the Balance Sheet as of a specified date."""
        result = api_request("GET", f"/finance/balance-sheet?date={as_of_date}")
        print(f"[FINANCE] Balance Sheet fetched for {as_of_date}")
        return result


