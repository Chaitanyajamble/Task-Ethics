@dataclass
class InventoryItem:
    """Represents a product/item in Task Ethics  Inventory."""
    item_code:    str
    item_name:    str
    category:     str
    unit_of_measure: str          # e.g. 'PCS', 'KG', 'MTR'
    reorder_level: int
    reorder_qty:  int
    hsn_code:     str             # Required for GST compliance
    gst_rate:     float           # GST percentage: 0, 5, 12, 18, 28
    unit_price:   float
    warehouse:    str = "WH-001"


class InventoryManagement:
    """ Task Ethics Inventory Management module."""

    def add_item(self, item: InventoryItem) -> dict:
        """Create a new inventory item."""
        result = api_request("POST", "/inventory/items", asdict(item))
        if "item_id" in result:
            print(f"[INVENTORY] Item '{item.item_name}' created: ID={result['item_id']}")
        return result

    def get_stock_levels(self, warehouse: str = None) -> dict:
        """
        Get current stock levels, optionally filtered by warehouse.

        Args:
            warehouse : Warehouse code; if None, returns all warehouses.
        """
        endpoint = "/inventory/stock-levels"
        if warehouse:
            endpoint += f"?warehouse={warehouse}"
        result = api_request("GET", endpoint)
        items = result.get("items", [])
        print(f"[INVENTORY] Stock levels: {len(items)} items retrieved")
        for item in items[:5]:   # Preview first 5
            print(f"  • {item.get('item_name')}: {item.get('quantity')} {item.get('uom')}")
        return result

    def create_stock_transfer(
        self, item_code: str, qty: float,
        from_warehouse: str, to_warehouse: str
    ) -> dict:
        """Transfer stock between warehouses."""
        payload = {
            "item_code":      item_code,
            "quantity":       qty,
            "from_warehouse": from_warehouse,
            "to_warehouse":   to_warehouse,
            "transfer_date":  str(date.today()),
        }
        result = api_request("POST", "/inventory/stock-transfer", payload)
        print(f"[INVENTORY] Transfer: {qty} of {item_code}  "
              f"{from_warehouse} → {to_warehouse}  |  Status: {result.get('status')}")
        return result

    def get_low_stock_alerts(self) -> List[dict]:
        """Retrieve items that have fallen below their reorder level."""
        result = api_request("GET", "/inventory/low-stock-alerts")
        alerts = result.get("alerts", [])
        if alerts:
            print(f"[INVENTORY] ⚠ {len(alerts)} items below reorder level:")
            for a in alerts:
                print(f"  • {a['item_name']}: Current={a['current_qty']}, "
                      f"Reorder Level={a['reorder_level']}")
        else:
            print("[INVENTORY] All items are adequately stocked.")
        return alerts


