class GSTCompliance:
    """
    Task Ethics  GST module.
    Covers GSTR-1, GSTR-3B generation and e-invoicing.
    """

    def generate_gstr1(self, month: int, year: int) -> dict:
        """
        Generate GSTR-1 (outward supplies return) for a given month.

        Args:
            month : Return month (1-12)
            year  : Return year
        """
        payload = {"month": month, "year": year}
        result  = api_request("POST", "/gst/gstr1/generate", payload)
        if "summary" in result:
            s = result["summary"]
            print(f"[GST] GSTR-1 {month}/{year}: "
                  f"B2B=₹{s.get('b2b_sales', 0):,.2f} | "
                  f"B2C=₹{s.get('b2c_sales', 0):,.2f} | "
                  f"Total Tax=₹{s.get('total_tax', 0):,.2f}")
        return result

    def generate_gstr3b(self, month: int, year: int) -> dict:
        """Generate GSTR-3B (monthly summary return)."""
        payload = {"month": month, "year": year}
        result  = api_request("POST", "/gst/gstr3b/generate", payload)
        if "liability" in result:
            l = result["liability"]
            print(f"[GST] GSTR-3B {month}/{year}: "
                  f"CGST=₹{l.get('cgst', 0):,.2f} | "
                  f"SGST=₹{l.get('sgst', 0):,.2f} | "
                  f"IGST=₹{l.get('igst', 0):,.2f} | "
                  f"ITC=₹{l.get('itc', 0):,.2f}")
        return result

    def generate_e_invoice(self, invoice_id: str) -> dict:
        """
        Generate a government-compliant e-invoice with IRN and QR code.

        Args:
            invoice_id : Sales invoice ID from TASK ETHICS
        """
        result = api_request("POST", f"/gst/e-invoice/{invoice_id}/generate")
        if "irn" in result:
            print(f"[GST] E-Invoice generated: IRN={result['irn']} | "
                  f"Ack No={result.get('ack_number')} | "
                  f"QR Code: {'Available' if result.get('qr_code') else 'Pending'}")
        return result

    def calculate_gst(self, base_amount: float, gst_rate: float, is_interstate: bool) -> dict:
        """
        Utility: Calculate GST split (CGST+SGST for intra-state, IGST for inter-state).

        Args:
            base_amount   : Taxable value before GST
            gst_rate      : GST rate (e.g., 18 for 18%)
            is_interstate : True = IGST, False = CGST + SGST

        Returns:
            dict with tax components and total
        """
        total_tax = base_amount * gst_rate / 100
        if is_interstate:
            result = {
                "base_amount": base_amount,
                "igst":        round(total_tax, 2),
                "cgst":        0,
                "sgst":        0,
                "total_tax":   round(total_tax, 2),
                "grand_total": round(base_amount + total_tax, 2),
            }
        else:
            half_tax = total_tax / 2
            result = {
                "base_amount": base_amount,
                "igst":        0,
                "cgst":        round(half_tax, 2),
                "sgst":        round(half_tax, 2),
                "total_tax":   round(total_tax, 2),
                "grand_total": round(base_amount + total_tax, 2),
            }
        return result


