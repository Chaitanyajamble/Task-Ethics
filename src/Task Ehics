        result = api_request("POST", "/hr/payroll/run", payload)
        if "summary" in result:
            s = result["summary"]
            print(f"[HR] Payroll {month}/{year}: "
                  f"Employees={s.get('employee_count')} | "
                  f"Gross=₹{s.get('total_gross', 0):,.2f} | "
                  f"Net=₹{s.get('total_net', 0):,.2f} | "
                  f"TDS=₹{s.get('total_tds', 0):,.2f} | "
                  f"PF=₹{s.get('total_pf', 0):,.2f}")
        return result

