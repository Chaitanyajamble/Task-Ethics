# CONFIGURATION
# ─────────────────────────────────────────────
BASE_URL = "https://ethics.task.online/api/v1"   # Replace with actual API base
API_KEY  = "YOUR_API_KEY_HERE"                     # Replace with your API key

HEADERS = {
    "Content-Type": "application/json",
    "Authorization": f"Bearer {API_KEY}",
    "Accept": "application/json",
}


# ─────────────────────────────────────────────
# HELPER — Generic HTTP request handler
# ─────────────────────────────────────────────
def api_request(method: str, endpoint: str, payload: dict = None) -> dict:
    """
    Generic API request wrapper for Task Ehics ERP.

    Args:
        method   : HTTP method — 'GET', 'POST', 'PUT', 'DELETE'
        endpoint : API endpoint path (e.g. '/inventory/items')
        payload  : Optional request body as dict

    Returns:
        Parsed JSON response as dict, or error dict.
    """
    url = f"{BASE_URL}{endpoint}"
    try:
        response = requests.request(
            method=method.upper(),
            url=url,
            headers=HEADERS,
            json=payload,
            timeout=30,
        )
        response.raise_for_status()
        return response.json()
    except requests.exceptions.HTTPError as e:
        return {"error": f"HTTP error: {e}", "status_code": response.status_code}
    except requests.exceptions.ConnectionError:
        return {"error": "Connection failed. Check BASE_URL and network."}
    except requests.exceptions.Timeout:
        return {"error": "Request timed out."}
    except Exception as e:
        return {"error": str(e)}


