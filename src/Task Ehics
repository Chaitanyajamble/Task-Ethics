class FinancialManagement:
    """
    Task Ethics Financial Management module.
    Covers: General Ledger, Journal Entries, Financial Reports.
    """

    def create_journal_entry(self, entry: JournalEntry) -> dict:
        """Post a journal entry to the general ledger."""
        payload = asdict(entry)
        result  = api_request("POST", "/finance/journal-entries", payload)
        if "entry_id" in result:
            print(f"[FINANCE] Journal entry created: ID={result['entry_id']}")
        else:
            print(f"[FINANCE] Error: {result.get('error')}")
