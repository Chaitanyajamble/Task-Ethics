@dataclass
class SalesOrderLine:
    item_code: str
    item_name: str
    qty:       float
    unit_price: float
    gst_rate:  float     # GST %
    discount:  float = 0.0

    @property
    def taxable_amount(self) -> float:
        return (self.qty * self.unit_price) * (1 - self.discount / 100)

    @property
    def gst_amount(self) -> float:
        return self.taxable_amount * (self.gst_rate / 100)

    @property
    def total(self) -> float:
        return self.taxable_amount + self.gst_amount


@dataclass
class SalesOrder:
    customer_id:  str
    order_date:   str
    delivery_date: str
    items:        List[SalesOrderLine] = field(default_factory=list)
    notes:        str = ""

    @property
    def grand_total(self) -> float:
        return sum(line.total for line in self.items)


class SalesManagement:
    """Task Ethics  Sales Management module."""

    def create_sales_order(self, order: SalesOrder) -> dict:
        """Submit a new sales order."""
        payload = {
            "customer_id":   order.customer_id,
            "order_date":    order.order_date,
            "delivery_date": order.delivery_date,
            "notes":         order.notes,
            "items": [
                {
                    "item_code":      line.item_code,
                    "item_name":      line.item_name,
                    "qty":            line.qty,
                    "unit_price":     line.unit_price,
                    "discount":       line.discount,
                    "gst_rate":       line.gst_rate,
                    "taxable_amount": line.taxable_amount,
                    "gst_amount":     line.gst_amount,
                    "total":          line.total,
                }
                for line in order.items
            ],
            "grand_total": order.grand_total,
        }
        result = api_request("POST", "/sales/orders", payload)
        print(f"[SALES] Order created for customer {order.customer_id} | "
              f"Total: ₹{order.grand_total:,.2f} | ID: {result.get('order_id')}")
        return result

    def generate_invoice(self, order_id: str) -> dict:
        """Generate a GST-compliant tax invoice from a confirmed sales order."""
        result = api_request("POST", f"/sales/orders/{order_id}/invoice")
        print(f"[SALES] Invoice generated: {result.get('invoice_number')} | "
              f"Amount: ₹{result.get('invoice_amount', 0):,.2f}")
        return result

    def get_sales_dashboard(self, period: str = "this_month") -> dict:
        """
        Retrieve sales KPIs and analytics.

        Args:
            period : 'today', 'this_week', 'this_month', 'this_year'
        """
        result = api_request("GET", f"/sales/dashboard?period={period}")
        if "kpis" in result:
            k = result["kpis"]
            print(f"[SALES] Dashboard ({period}): "
                  f"Orders={k.get('total_orders')} | "
                  f"Revenue=₹{k.get('total_revenue', 0):,.2f} | "
                  f"Avg Order=₹{k.get('avg_order_value', 0):,.2f}")
        return result


