@dataclass
class PurchaseOrderLine:
    item_code:  str
    item_name:  str
    qty:        float
    unit_price: float
    gst_rate:   float


@dataclass
class PurchaseOrder:
    vendor_id:     str
    order_date:    str
    expected_date: str
    items:         List[PurchaseOrderLine] = field(default_factory=list)
    payment_terms: str = "NET30"

    @property
    def total_amount(self) -> float:
        return sum(
            (line.qty * line.unit_price) * (1 + line.gst_rate / 100)
            for line in self.items
        )


class ProcurementManagement:
    """Task Ethics Procurement Management module."""

    def create_purchase_order(self, po: PurchaseOrder) -> dict:
        """Submit a new purchase order to a vendor."""
        payload = {
            "vendor_id":     po.vendor_id,
            "order_date":    po.order_date,
            "expected_date": po.expected_date,
            "payment_terms": po.payment_terms,
            "total_amount":  po.total_amount,
            "items": [
                {
                    "item_code":  line.item_code,
                    "item_name":  line.item_name,
                    "qty":        line.qty,
                    "unit_price": line.unit_price,
                    "gst_rate":   line.gst_rate,
                    "line_total": (line.qty * line.unit_price) * (1 + line.gst_rate / 100),
                }
                for line in po.items
            ],
        }
        result = api_request("POST", "/procurement/purchase-orders", payload)
        print(f"[PROCUREMENT] PO created for vendor {po.vendor_id} | "
              f"Total: ₹{po.total_amount:,.2f} | PO#: {result.get('po_number')}")
        return result

    def approve_purchase_order(self, po_id: str, approver_id: str) -> dict:
        """Approve a pending purchase order."""
        payload = {"approver_id": approver_id, "approved_at": str(datetime.now())}
        result  = api_request("PUT", f"/procurement/purchase-orders/{po_id}/approve", payload)
        print(f"[PROCUREMENT] PO {po_id} approved by {approver_id}: {result.get('status')}")
        return result

    def receive_goods(self, po_id: str, received_items: List[dict]) -> dict:
        """
        Record goods receipt against a purchase order.

        Args:
            po_id          : Purchase order ID
            received_items : List of dicts: [{"item_code": ..., "received_qty": ...}]
        """
        payload = {
            "po_id":          po_id,
            "receipt_date":   str(date.today()),
            "received_items": received_items,
        }
        result = api_request("POST", "/procurement/goods-receipt", payload)
        print(f"[PROCUREMENT] Goods received for PO {po_id}: GRN={result.get('grn_number')}")
        return result


