class TaskAuth:
    """Handles Task Ethics authentication and token management."""

    def __init__(self, username: str, password: str, company_code: str):
        self.username     = username
        self.password     = password
        self.company_code = company_code
        self.token        = None

    def login(self) -> str:
        """
        Authenticate with Task Ethics and retrieve a session token.

        Returns:
            Access token string on success, or empty string on failure.
        """
        payload = {
            "username":     self.username,
            "password":     self.password,
            "company_code": self.company_code,
        }
        result = api_request("POST", "/auth/login", payload)

        if "token" in result:
            self.token = result["token"]
            # Update global headers with fresh token
            HEADERS["Authorization"] = f"Bearer {self.token}"
            print(f"[AUTH] Login successful. Token expires: {result.get('expires_at', 'N/A')}")
            return self.token
        else:
            print(f"[AUTH] Login failed: {result.get('error')}")
            return ""

    def logout(self):
        """Invalidate the current session token."""
        result = api_request("POST", "/auth/logout")
        print(f"[AUTH] Logged out: {result.get('message', 'Done')}")


