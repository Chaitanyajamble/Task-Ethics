        """
        Record employee attendance for a day.

        Args:
            employee_id : Employee ID
            check_in    : Check-in datetime string 'YYYY-MM-DD HH:MM'
            check_out   : Check-out datetime string 'YYYY-MM-DD HH:MM'
        """
        payload = {
            "employee_id": employee_id,
            "date":        check_in[:10],
            "check_in":    check_in,
            "check_out":   check_out,
        }
        result = api_request("POST", "/hr/attendance", payload)
        print(f"[HR] Attendance for {employee_id}: {check_in} → {check_out} | "
              f"Hours: {result.get('working_hours', 'N/A')}")
        return result

    def apply_leave(
        self, employee_id: str, leave_type: str,
        from_date: str, to_date: str, reason: str
    ) -> dict:
        """Submit a leave application."""
        payload = {
            "employee_id": employee_id,
            "leave_type":  leave_type,   # 'CL', 'SL', 'EL', 'LWP'
            "from_date":   from_date,
            "to_date":     to_date,
            "reason":      reason,
        }
