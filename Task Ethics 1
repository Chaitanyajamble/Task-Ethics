class FinancialAI:
    """
    Use-cases:
      • Summarise P&L in plain English for CFO / management
      • Detect budget overruns and suggest corrective actions
      • Auto-classify GL entries
      • GST compliance Q&A
    """

    SYSTEM = (
        "You are an expert finance controller integrated with TASK ETHICS. "
        "You understand Indian accounting standards, GST regulations, and "
        "multi-entity financial consolidation. Be concise and accurate."
    )

    def summarise_pnl(self, pnl_data: dict) -> str:
        """
        pnl_data example:
          {"revenue": 5000000, "cogs": 3200000, "opex": 900000,
           "period": "Q1 FY2025-26", "currency": "INR"}
        """
        prompt = (
            f"Here is the P&L summary for {pnl_data['period']}:\n"
            f" Revenue : ₹{pnl_data['revenue']:,}\n"
            f" COGS : ₹{pnl_data['cogs']:,}\n"
            f" OpEx : ₹{pnl_data['opex']:,}\n"
            f" Net : ₹{pnl_data['revenue'] - pnl_data['cogs'] - pnl_data['opex']:,}\n\n"
            "Write a 3-sentence management-level summary highlighting performance, "
            "gross margin %, and one actionable recommendation."
        )
        return llm.chat(self.SYSTEM, prompt)

    def classify_gl_entry(self, description: str, amount: float) -> dict:
        """Auto-classify a journal description into a GL account code."""
        prompt = (
            f"Transaction description: '{description}'\n"
            f"Amount: ₹{amount:,.2f}\n\n"
            "Return JSON with keys: gl_account_code, gl_account_name, "
            "cost_center, gst_applicable (bool), confidence (0-1)."
        )
        return llm.chat_json(self.SYSTEM, prompt)

    def budget_variance_insight(self, budget: float, actual: float, category: str) -> str:
        variance_pct = ((actual - budget) / budget) * 100
        prompt = (
            f"Category: {category}\n"
            f"Budget: ₹{budget:,} | Actual: ₹{actual:,} | "
            f"Variance: {variance_pct:+.1f}%\n\n"
            "In 2 sentences explain the risk level and suggest one corrective action."
        )
        return llm.chat(self.SYSTEM, prompt)

    def gst_compliance_query(self, question: str) -> str:
        """Answer GST-related queries in plain language."""
        return llm.chat(
            self.SYSTEM + " Focus strictly on India GST rules.",
            question,
            temperature=0.1,
        )


