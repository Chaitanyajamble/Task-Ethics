class BusinessIntelligenceAI:
    """
    Use-cases:
      • NL query → SQL (for TASK ETHICS database)
      • Narrate KPI dashboards in plain English
      • Anomaly detection commentary
      • Executive report generation
    """

    SYSTEM = (
        "You are a Business Intelligence assistant for TASK ETHICS. "
        "You translate business questions into SQL, explain dashboards, "
        "and generate executive reports from structured data."
    )

    # Simplified TASK ETHICS schema excerpt for NL→SQL
    DB_SCHEMA = """
    Tables:
      sales_orders(id, customer_id, order_date, total_amount, status, branch_id)
      inventory(sku, item_name, qty_on_hand, reorder_level, warehouse_id)
      employees(id, name, department, salary, hire_date, status)
      gl_transactions(id, date, account_code, debit, credit, description)
      customers(id, name, segment, city, created_at)
    """

    def nl_to_sql(self, natural_language_query: str) -> str:
        prompt = (
            f"Database schema:\n{self.DB_SCHEMA}\n\n"
            f"User question: {natural_language_query}\n\n"
            "Write a clean PostgreSQL query that answers the question. "
            "Return only the SQL statement, no explanation."
        )
        return llm.chat(self.SYSTEM, prompt, temperature=0.0)

    def narrate_kpi_dashboard(self, kpis: dict) -> str:
        """
        kpis: {"revenue_mtd": 2100000, "revenue_target": 2500000,
                "orders_count": 412, "avg_order_value": 5097,
                "top_product": "TASK ETHICS Pro", "csat_score": 4.3}
        """
        prompt = (
            f"KPI snapshot for today ({date.today()}):\n"
            f"{json.dumps(kpis, indent=2)}\n\n"
            "Write a 4-sentence executive summary a CEO can read in 30 seconds. "
            "Highlight wins, gaps, and one priority action."
        )
        return llm.chat(self.SYSTEM, prompt)

    def detect_anomaly_comment(self, metric: str, value: float,
                                historical_avg: float, std_dev: float) -> str:
        z_score = (value - historical_avg) / std_dev if std_dev else 0
        prompt = (
            f"Metric: {metric}\n"
            f"Today's value: {value}\n"
            f"Historical avg: {historical_avg} | Std Dev: {std_dev}\n"
            f"Z-score: {z_score:.2f}\n\n"
            "In one sentence, explain whether this is an anomaly and what might be causing it."
        )
        return llm.chat(self.SYSTEM, prompt)

    def generate_executive_report(self, report_data: dict) -> str:
        """
        report_data: monthly rolled-up metrics across Finance, HR, Sales, Ops
        """
        prompt = (
            f"Monthly Business Review data:\n{json.dumps(report_data, indent=2)}\n\n"
            "Write a structured executive report with sections: "
            "Financial Performance, Operational Highlights, HR Snapshot, "
            "Key Risks, and Next Month Priorities. Use professional business language."
        )
        return llm.chat(self.SYSTEM, prompt, temperature=0.4)


