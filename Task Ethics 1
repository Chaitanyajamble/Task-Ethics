class ERPSupportChatbot:
    """
    Multi-turn chatbot for:
      • Employee Self-Service (ESS) — leave, payslip, policy queries
      • Customer-facing — order status, invoice queries, support tickets
    Maintains conversation history per session.
    """

    SYSTEM = (
        "You are TASK Assistant, a helpful ERP support bot for TASK Software. "
        "You help employees and customers with queries about orders, invoices, "
        "leave balances, payslips, and general ERP navigation. "
        "If you cannot answer, politely escalate to the support team at support@TASKsoft.com."
    )

    def __init__(self):
        self.sessions: dict[str, list[dict]] = {}

    def chat(self, session_id: str, user_message: str) -> str:
        if session_id not in self.sessions:
            self.sessions[session_id] = []

        history = self.sessions[session_id]
        history.append({"role": "user", "content": user_message})

        response = llm.client.chat.completions.create(
            model=llm.model,
            messages=[{"role": "system", "content": self.SYSTEM}] + history,
            temperature=0.4,
        )
        reply = response.choices[0].message.content.strip()
        history.append({"role": "assistant", "content": reply})
        return reply

    def reset_session(self, session_id: str):
        self.sessions.pop(session_id, None)


