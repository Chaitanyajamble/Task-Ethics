class InventoryAI:
    """
    Use-cases:
      • Demand forecasting narrative
      • Auto-generate purchase orders from low-stock triggers
      • Supplier evaluation summary
      • Warehouse slotting recommendations
    """

    SYSTEM = (
        "You are a supply chain analyst integrated into TASK ETHICS. "
        "You help Indian SMEs optimise inventory, reduce stockouts, "
        "and negotiate better with suppliers."
    )

    def demand_forecast_narrative(self, item: str, sales_history: list[int]) -> str:
        """
        sales_history: monthly units sold, oldest → newest, e.g. [120, 135, 110, 150, 170]
        """
        months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]
        history_str = ", ".join(
            f"{months[i % 12]}: {v}" for i, v in enumerate(sales_history)
        )
        prompt = (
            f"Item: {item}\nSales history (units): {history_str}\n\n"
            "Forecast next 3 months demand, explain the trend, and recommend "
            "a reorder point. Keep it under 100 words."
        )
        return llm.chat(self.SYSTEM, prompt)

    def generate_purchase_order_draft(self, low_stock_items: list[dict]) -> str:
        """
        low_stock_items: [{"sku", "name", "current_stock", "reorder_qty", "preferred_supplier"}]
        """
        prompt = (
            f"Generate a purchase order draft for the following low-stock items:\n"
            f"{json.dumps(low_stock_items, indent=2)}\n\n"
            "Format as a clean PO table with columns: SKU, Item, Qty to Order, "
            "Supplier. Add a brief justification note at the top."
        )
        return llm.chat(self.SYSTEM, prompt)

    def evaluate_supplier(self, supplier_data: dict) -> dict:
        """
        supplier_data: {"name", "on_time_delivery_pct", "defect_rate_pct",
                         "avg_lead_days", "payment_terms", "years_of_relation"}
        """
        prompt = (
            f"Evaluate this supplier:\n{json.dumps(supplier_data, indent=2)}\n\n"
            "Return JSON: overall_score (int 0-100), grade ('A'|'B'|'C'|'D'), "
            "strengths (list), risks (list), recommendation (str)."
        )
        return llm.chat_json(self.SYSTEM, prompt)

    def warehouse_slotting_advice(self, warehouse_data: dict) -> str:
        """
        warehouse_data: {"fast_moving_items": list, "slow_moving_items": list,
                          "zones": ["A","B","C"], "picking_frequency": dict}
        """
        prompt = (
            f"Warehouse layout data:\n{json.dumps(warehouse_data, indent=2)}\n\n"
            "Recommend optimal zone assignment for items to minimise picker travel time. "
            "Use ABC analysis logic. Max 150 words."
        )
        return llm.chat(self.SYSTEM, prompt)


