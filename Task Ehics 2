@router.post("/journal-entries", response_model=APIResponse[JournalEntryOut], status_code=201)
async def create_journal_entry(
    payload: JournalEntryCreate,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(require_permissions({Permission.FINANCE_WRITE})),
):
    """
    Create a double-entry journal entry.
    Validation:
     - Sum of debits MUST equal sum of credits (balanced entry)
     - Minimum 2 lines required
     - Future-dated entries allowed but flagged
    GST lines auto-split into CGST/SGST (intra-state) or IGST (inter-state).
    """
    total_debit  = sum(l.debit  for l in payload.lines)
    total_credit = sum(l.credit for l in payload.lines)

    if round(total_debit, 2) != round(total_credit, 2):
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"Unbalanced entry: debits={total_debit} ≠ credits={total_credit}",
        )

    # Auto-generate entry number: JE/2026-27/00001
    # entry = await FinanceRepository(db).create_journal_entry(payload, current_user)

    return APIResponse.ok(
        data=JournalEntryOut(
            id="00000000-0000-0000-0000-000000000002",
            entry_number="JE/2026-27/00001",
            entry_date=payload.entry_date,
            reference=payload.reference,
            narration=payload.narration,
            status=EntryStatus.DRAFT,
            total_debit=total_debit,
            total_credit=total_credit,
            currency=payload.currency,
            lines=[l.model_dump() for l in payload.lines],
            created_at="2026-06-15T00:00:00Z",
            updated_at="2026-06-15T00:00:00Z",
        ),
        message="Journal entry created (draft)",
    )


