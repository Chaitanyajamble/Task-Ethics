"""
app/api/v1/endpoints/procurement.py
BRS: Procurement Management
Covers: Supplier master, Purchase Requisition → PO → GRN → Bill → Payment
"""
from datetime import date
from enum import Enum
from typing import List, Optional
from uuid import UUID

from fastapi import APIRouter, Depends, Query
from pydantic import BaseModel, Field, EmailStr
from sqlalchemy.ext.asyncio import AsyncSession

from app.core.security import Permission, require_permissions
from app.db.session import get_db
from app.schemas.base import APIResponse, AuditMixin, PaginationMeta, PaginationParams


# ─── Procurement Router ─────────────────────────────────────────────────────

router_procurement = APIRouter(prefix="/procurement", tags=["Procurement"])


class POStatus(str, Enum):
    DRAFT     = "draft"
    SENT      = "sent"
    PARTIAL   = "partial_received"
    RECEIVED  = "received"
    BILLED    = "billed"
    CANCELLED = "cancelled"


class SupplierCreate(BaseModel):
    name: str
    gstin: Optional[str] = None
    contact_person: str
    email: EmailStr
    mobile: str
    address: str
    payment_terms: str = "30 days net"
    credit_limit: float = Field(default=0.0, ge=0)


class POLineCreate(BaseModel):
    item_id: UUID
    quantity: float = Field(..., gt=0)
    unit_price: float = Field(..., ge=0)
    expected_delivery_date: Optional[date] = None


class PurchaseOrderCreate(BaseModel):
    supplier_id: UUID
    order_date: date
    delivery_warehouse_id: UUID
    lines: List[POLineCreate] = Field(..., min_length=1)
    notes: Optional[str] = None
    auto_approve_below: float = Field(
        default=50000.0,
        description="Auto-approve POs below this value (configurable per company policy)"
    )


class GRNCreate(BaseModel):
    """Goods Receipt Note — confirms physical receipt of items."""
    po_id: UUID
    receipt_date: date
    lines: List[dict]   # {po_line_id, received_qty, batch_number?}
    quality_check_passed: bool = True
    remarks: Optional[str] = None


@router_procurement.post("/suppliers", response_model=APIResponse[dict], status_code=201)
async def create_supplier(
    payload: SupplierCreate,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(require_permissions({Permission.PURCHASE_WRITE})),
):
    return APIResponse.ok(data={"supplier_id": "sup_001"}, message="Supplier created")


@router_procurement.get("/suppliers", response_model=APIResponse[List[dict]])
async def list_suppliers(
    search: Optional[str] = Query(None),
    pagination: PaginationParams = Depends(),
    current_user: dict = Depends(require_permissions({Permission.PURCHASE_READ})),
    db: AsyncSession = Depends(get_db),
):
    return APIResponse.ok(data=[], meta=PaginationMeta(total=0, page=1, page_size=25, total_pages=0))


@router_procurement.post("/purchase-orders", response_model=APIResponse[dict], status_code=201)
async def create_po(
    payload: PurchaseOrderCreate,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(require_permissions({Permission.PURCHASE_WRITE})),
):
    """
    Create Purchase Order.
    Flow: PR → PO → Send to Supplier → GRN → Supplier Bill → Payment
    Auto-approval: POs below threshold bypass approval workflow.
    3-way match on bill: PO qty = GRN qty = Invoice qty.
    """
    return APIResponse.ok(data={"po_number": "PO/2026-27/001"}, message="PO created")


@router_procurement.post("/grn", response_model=APIResponse[dict], status_code=201)
async def create_grn(
    payload: GRNCreate,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(require_permissions({Permission.PURCHASE_WRITE})),
):
    """
    Record Goods Receipt.
    Triggers: inventory increase, GRN journal entry, PO status update.
    If quality check fails: creates quality rejection note.
    """
    return APIResponse.ok(data={"grn_number": "GRN/2026-27/001"}, message="GRN recorded")


