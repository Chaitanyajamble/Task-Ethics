"""
app/middleware/rate_limiter.py  — sliding-window rate limiter (in-process)
app/middleware/request_id.py   — injects X-Request-ID header
app/middleware/audit_log.py    — logs every mutating request for compliance
"""

# ─────────────────────────── rate_limiter.py ────────────────────────────────
# Save as separate files in production; combined here for brevity.

from collections import defaultdict, deque
from time import time

from starlette.middleware.base import BaseHTTPMiddleware
from starlette.requests import Request
from starlette.responses import JSONResponse

import logging
import uuid

logger = logging.getLogger("Task _erp")


class RateLimitMiddleware(BaseHTTPMiddleware):
    """
    Sliding-window rate limiter keyed by client IP.
    In production replace with Redis-backed token bucket.
    """

    def __init__(self, app, calls: int = 100, period: int = 60):
        super().__init__(app)
        self.calls = calls
        self.period = period
        self._windows: dict[str, deque] = defaultdict(deque)

    async def dispatch(self, request: Request, call_next):
        # Skip health endpoints
        if request.url.path in ("/health", "/ready"):
            return await call_next(request)

        ip = request.client.host if request.client else "unknown"
        now = time()
        window = self._windows[ip]

        # Evict timestamps outside the current window
        while window and window[0] < now - self.period:
            window.popleft()

        if len(window) >= self.calls:
            return JSONResponse(
                status_code=429,
                content={"success": False, "message": "Rate limit exceeded. Retry after 60 seconds."},
                headers={"Retry-After": "60"},
            )

        window.append(now)
        response = await call_next(request)
        response.headers["X-RateLimit-Limit"] = str(self.calls)
        response.headers["X-RateLimit-Remaining"] = str(self.calls - len(window))
        return response


# ─────────────────────────── request_id.py ──────────────────────────────────

class RequestIDMiddleware(BaseHTTPMiddleware):
    """Attaches a unique request-id to every request for distributed tracing."""

    async def dispatch(self, request: Request, call_next):
        req_id = request.headers.get("X-Request-ID") or str(uuid.uuid4())
        request.state.request_id = req_id
        response = await call_next(request)
        response.headers["X-Request-ID"] = req_id
        return response


# ─────────────────────────── audit_log.py ───────────────────────────────────

AUDITED_METHODS = {"POST", "PUT", "PATCH", "DELETE"}


class AuditLogMiddleware(BaseHTTPMiddleware):
    """
    Logs every state-changing request — required for GST audit trail
    and ISO 27001 compliance.
    """

    async def dispatch(self, request: Request, call_next):
        response = await call_next(request)

        if request.method in AUDITED_METHODS:
            user = getattr(request.state, "user_id", "anonymous")
            logger.info(
                "AUDIT | %s %s | user=%s | status=%s | req_id=%s",
                request.method,
                request.url.path,
                user,
                response.status_code,
                getattr(request.state, "request_id", "-"),
            )

        return response
