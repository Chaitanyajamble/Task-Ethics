@router.post("/invoices", response_model=APIResponse[GSTInvoiceOut], status_code=201)
async def create_gst_invoice(
    payload: GSTInvoiceCreate,
    background_tasks: BackgroundTasks,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(require_permissions({Permission.FINANCE_WRITE})),
):
    """
    Create a GST-compliant tax invoice.

    Auto-calculation logic:
    - Intra-state supply → split rate into equal CGST + SGST
    - Inter-state supply → entire rate as IGST
    - Place of Supply determines IGST vs CGST+SGST
    - Reverse Charge → buyer liable to pay tax (flag on invoice)
    - If is_e_invoice=True → POST to NIC IRP API to get IRN + QR code

    Invoice number format: GSTIN/FY/Seq e.g. 36ABCDE1234F1Z5/2026-27/0001
    """
    if payload.buyer_gstin and not validate_gstin(payload.buyer_gstin):
        from fastapi import HTTPException
        raise HTTPException(status_code=400, detail="Invalid buyer GSTIN format")

    # Calculate tax
    seller_state = payload.seller_gstin[:2]   # First 2 digits = state code
    is_intra_state = seller_state == payload.place_of_supply

    total_cgst = total_sgst = total_igst = total_cess = total_taxable = 0.0
    for item in payload.line_items:
        taxable = item.taxable_value
        total_taxable += taxable
        if is_intra_state:
            cgst = taxable * (item.gst_rate / 2) / 100
            sgst = taxable * (item.gst_rate / 2) / 100
            total_cgst += cgst
            total_sgst += sgst
        else:
            igst = taxable * item.gst_rate / 100
            total_igst += igst
        total_cess += taxable * item.cess_rate / 100

    total_tax = total_cgst + total_sgst + total_igst + total_cess
    invoice_value = total_taxable + total_tax

    # background_tasks.add_task(generate_irn, payload) if payload.is_e_invoice

    return APIResponse.ok(
        data=GSTInvoiceOut(
            id="00000000-0000-0000-0000-000000000020",
            invoice_number="36ABCDE1234F1Z5/2026-27/0001",
            invoice_date=payload.invoice_date,
            supply_type=payload.supply_type,
            buyer_name=payload.buyer_name,
            buyer_gstin=payload.buyer_gstin,
            taxable_value=round(total_taxable, 2),
            total_cgst=round(total_cgst, 2),
            total_sgst=round(total_sgst, 2),
            total_igst=round(total_igst, 2),
            total_cess=round(total_cess, 2),
            total_tax=round(total_tax, 2),
            invoice_value=round(invoice_value, 2),
            irn=None,
            created_at="2026-06-15T00:00:00Z",
            updated_at="2026-06-15T00:00:00Z",
        ),
        message="GST invoice created",
    )


