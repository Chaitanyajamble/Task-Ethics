@router.post("/payroll/run", response_model=APIResponse[dict], status_code=201)
async def run_payroll(
    payload: PayrollRunRequest,
    db: AsyncSession = Depends(get_db),
    current_user: dict = Depends(require_permissions({Permission.PAYROLL_RUN})),
):
    """
    Process payroll for a given month/year.

    Computation flow:
    1. Fetch attendance data for the period
    2. Calculate LOP (Loss of Pay) for unauthorised absences
    3. Compute gross = basic + HRA + special + OT pay + arrears
    4. Compute statutory deductions:
       - PF employee: 12% of basic (capped at ₹15,000 basic)
       - PF employer: 12% (cost to company)
       - ESI employee: 0.75% of gross (if gross ≤ ₹21,000/month)
       - ESI employer: 3.25%
       - Professional Tax: state-specific monthly slab
